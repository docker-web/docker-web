#!/bin/bash

# Pre-commit hook for docker-web
# Runs tests ONLY when committing changes to src/ files
# Does NOT interfere with normal docker-web commands

set -e

# Get the docker-web directory
DOCKERWEB_DIR="$(git rev-parse --show-toplevel 2>/dev/null)"
cd "$DOCKERWEB_DIR" || exit 1

# Check if there are staged changes in src/ (the stuff that matters for tests)
if ! git diff --cached --quiet -- src/ .git-hook-pre-commit 2>/dev/null; then
  # There ARE changes to test
  echo -e "\033[1;33m[*]\033[0m Running E2E tests before commit..."
  
  if bash src/core/test.sh 2>&1; then
    echo -e "\033[0;32m[✓]\033[0m Tests passed - proceeding with commit"
    exit 0
  else
    echo -e "\033[0;31m[✗]\033[0m Tests failed - commit aborted"
    echo "Run: git commit --no-verify  (to bypass tests)"
    exit 1
  fi
else
  # No changes to src/, skip tests
  exit 0
fi
